---
// Custom search component using Pagefind API directly
---

<div class="relative mx-auto w-full max-w-sm">
  <label for="search-input" class="sr-only">Search articles</label>
  <div class="relative">
    <svg
      class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      type="text"
      id="search-input"
      placeholder="Search articles..."
      autocomplete="off"
      role="combobox"
      aria-autocomplete="list"
      aria-expanded="false"
      aria-controls="search-results"
      aria-haspopup="listbox"
      class="h-9 w-full rounded-md border border-input bg-background pl-9 pr-3 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
    />
  </div>
  <div
    id="search-results"
    role="listbox"
    aria-label="Search results"
    class="absolute left-0 right-0 top-full z-50 mt-2 hidden max-h-80 overflow-y-auto rounded-md border border-border bg-background shadow-lg"
  ></div>
</div>

<script>
  let pagefind: any = null;
  const RESULT_ID_PREFIX = "search-result";

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      // Use string concatenation to prevent Vite from resolving at build time
      const pagefindPath = "/pagefind/pagefind.js";
      pagefind = await import(/* @vite-ignore */ pagefindPath);
      await pagefind.init();
      return pagefind;
    } catch (e) {
      console.log("Pagefind not available (dev mode)");
      return null;
      }
  }

  function escapeHtml(value: string) {
    return value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function initSearch() {
    const globalWindow = window as any;
    if (typeof globalWindow.__cleanupSiteSearch === "function") {
      globalWindow.__cleanupSiteSearch();
    }

    const input = document.getElementById("search-input") as HTMLInputElement;
    const resultsContainer = document.getElementById(
      "search-results"
    ) as HTMLDivElement | null;
    if (!input || !resultsContainer) return;

    let debounceTimer: ReturnType<typeof setTimeout> | undefined;
    let activeIndex = -1;

    const getResultOptions = () =>
      Array.from(
        resultsContainer.querySelectorAll('[role="option"]')
      ) as HTMLAnchorElement[];

    const closeResults = () => {
      resultsContainer.classList.add("hidden");
      input.setAttribute("aria-expanded", "false");
      input.removeAttribute("aria-activedescendant");
      activeIndex = -1;
    };

    const openResults = () => {
      resultsContainer.classList.remove("hidden");
      input.setAttribute("aria-expanded", "true");
    };

    const updateActiveOption = (nextIndex: number) => {
      const options = getResultOptions();
      if (!options.length) return;

      activeIndex = (nextIndex + options.length) % options.length;

      options.forEach((option, index) => {
        const isActive = index === activeIndex;
        option.setAttribute("aria-selected", String(isActive));
        option.classList.toggle("bg-accent", isActive);
        option.classList.toggle("text-foreground", isActive);

        if (isActive) {
          input.setAttribute("aria-activedescendant", option.id);
          option.scrollIntoView({ block: "nearest" });
        }
      });
    };

    const renderMessage = (message: string) => {
      resultsContainer.innerHTML = `<div class="px-3 py-4 text-center text-sm text-muted-foreground" role="status">${escapeHtml(message)}</div>`;
      openResults();
    };

    const renderResults = (results: any[]) => {
      if (results.length === 0) {
        renderMessage("No results found");
        return;
      }

      resultsContainer.innerHTML = results
        .map((result: any, index: number) => {
          const title = escapeHtml(result.meta?.title || "Untitled");
          const date = escapeHtml(result.meta?.date || "");

          return `
            <a
              id="${RESULT_ID_PREFIX}-${index}"
              href="${result.url}"
              role="option"
              aria-selected="false"
              class="block px-3 py-2 transition-colors hover:bg-accent"
            >
              <div class="flex items-baseline justify-between gap-3">
                <span class="truncate text-sm font-medium text-foreground">${title}</span>
                ${date ? `<span class="flex-shrink-0 text-xs text-muted-foreground">${date}</span>` : ""}
              </div>
            </a>
          `;
        })
        .join("");

      openResults();
      activeIndex = -1;
      input.removeAttribute("aria-activedescendant");
    };

    const handleInput = async () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      const query = input.value.trim();

      if (!query) {
        resultsContainer.innerHTML = "";
        closeResults();
        return;
      }

      debounceTimer = setTimeout(async () => {
        const pf = await loadPagefind();
        if (!pf) {
          renderMessage("Search available after build");
          return;
        }

        const search = await pf.search(query);
        const results = await Promise.all(
          search.results.slice(0, 8).map((r: any) => r.data())
        );
        renderResults(results);
      }, 150);
    };

    const handleDocumentClick = (e: MouseEvent) => {
      if (
        !input.contains(e.target as Node) &&
        !resultsContainer.contains(e.target as Node)
      ) {
        closeResults();
      }
    };

    const handleKeyDown = (e: KeyboardEvent) => {
      const options = getResultOptions();

      if (e.key === "Escape") {
        closeResults();
        input.blur();
        return;
      }

      if (!options.length) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        updateActiveOption(activeIndex + 1);
        return;
      }

      if (e.key === "ArrowUp") {
        e.preventDefault();
        updateActiveOption(activeIndex - 1);
        return;
      }

      if (e.key === "Enter" && activeIndex >= 0) {
        e.preventDefault();
        options[activeIndex]?.click();
      }
    };

    input.addEventListener("input", handleInput);
    input.addEventListener("keydown", handleKeyDown);
    document.addEventListener("click", handleDocumentClick);

    globalWindow.__cleanupSiteSearch = () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      input.removeEventListener("input", handleInput);
      input.removeEventListener("keydown", handleKeyDown);
      document.removeEventListener("click", handleDocumentClick);
      closeResults();
    };
  }

  const globalWindow = window as any;
  if (globalWindow.__siteSearchPageLoadHandler) {
    document.removeEventListener(
      "astro:page-load",
      globalWindow.__siteSearchPageLoadHandler
    );
  }
  globalWindow.__siteSearchPageLoadHandler = initSearch;
  document.addEventListener("astro:page-load", initSearch);

  initSearch();
</script>
