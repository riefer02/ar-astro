---
import Layout from "./Layout.astro";
import { Badge } from "../components/ui/badge";
import { Button } from "../components/ui/button";
import { Toaster } from "../components/ui/toaster";
import { toast } from "../hooks/use-toast";
import ShareButton from "../components/ShareButton";
import PostNavigation from "../components/PostNavigation.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  frontmatter: CollectionEntry<"posts">["data"];
  body: string;
  prevPost: CollectionEntry<"posts"> | null;
  nextPost: CollectionEntry<"posts"> | null;
  currentSlug: string;
  allPosts: CollectionEntry<"posts">[];
}

const { frontmatter, body, prevPost, nextPost, currentSlug, allPosts } = Astro.props;

// Get the full current URL using Astro's built-in approach
const fullUrl = Astro.url.toString();
const publishedIso = new Date(frontmatter.pubDate).toISOString();

const metaTags = {
  title: frontmatter.title,
  description: frontmatter.description,
  image: frontmatter.image?.url?.src || frontmatter.image,
  url: fullUrl,
  type: "article" as const,
  article: {
    publishedTime: publishedIso,
    modifiedTime: publishedIso,
    author: frontmatter.author,
    tags: frontmatter.tags || [],
  },
};

const articleStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: frontmatter.title,
  description: frontmatter.description,
  image: [metaTags.image],
  datePublished: publishedIso,
  dateModified: publishedIso,
  author: {
    "@type": "Person",
    name: frontmatter.author,
  },
  mainEntityOfPage: fullUrl,
  keywords: (frontmatter.tags || []).join(", "),
  publisher: {
    "@type": "Person",
    name: "Andrew Riefenstahl",
    url: "https://andrewriefenstahl.com",
  },
};

// Format date nicely
const formatDate = (date) => {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

// Calculate reading time
const getReadingTime = (content) => {
  if (typeof content === "string") {
    const words = content.split(" ").length;
    const readingTime = Math.ceil(words / 200);
    return `${readingTime} min read`;
  }
  return "5 min read"; // fallback
};
---

<Layout metaTags={metaTags} structuredData={articleStructuredData}>
  <!-- Back Navigation -->
  <div class="px-6 pt-8">
    <div class="mx-auto max-w-4xl">
      <a
        href="/posts"
        class="mb-8 inline-flex items-center text-muted-foreground transition-colors duration-200 hover:text-foreground"
      >
        <svg
          class="mr-2 h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Writing
      </a>
    </div>
  </div>

  <!-- Main Article -->
  <article class="pb-16 px-6" data-pagefind-body>
    <!-- Hidden date for Pagefind -->
    <span data-pagefind-meta="date" class="hidden">{formatDate(frontmatter.pubDate)}</span>
    <div class="mx-auto max-w-4xl">
      <!-- Article Header (natural, no cards) -->
      <header class="mb-8 text-center">
        <!-- Meta Information -->
        <div
          class="mb-6 flex flex-col items-center justify-center gap-2 text-sm text-muted-foreground sm:flex-row sm:gap-6"
        >
          <!-- Date & Reading Time (stay together on mobile) -->
          <div class="flex items-center gap-4">
            <div class="flex items-center space-x-2">
              <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
              <span>{formatDate(frontmatter.pubDate)}</span>
            </div>
            <div class="flex items-center space-x-2">
              <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>{getReadingTime(body)}</span>
            </div>
          </div>
          <!-- Author (separate line on mobile, same line on desktop) -->
          <div class="flex items-center space-x-2">
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7-7h14a7 7 0 00-7-7z"
              ></path>
            </svg>
            <span>{frontmatter.author}</span>
          </div>
        </div>

        <!-- Title & Description -->
        <h1
          class="mb-6 text-3xl font-bold leading-tight text-foreground md:text-5xl"
          data-pagefind-meta="title"
        >
          {frontmatter.title}
        </h1>
        <p
          class="mx-auto mb-6 max-w-3xl text-lg leading-relaxed text-muted-foreground md:text-xl"
        >
          {frontmatter.description}
        </p>

        <!-- Tags -->
        {
          frontmatter.tags && frontmatter.tags.length > 0 && (
            <div class="mb-8 flex flex-wrap justify-center gap-2">
              {frontmatter.tags.map((tag) => (
                <Badge
                  variant="secondary"
                  className="bg-secondary text-foreground hover:bg-accent transition-colors"
                >
                  {tag}
                </Badge>
              ))}
            </div>
          )
        }
      </header>

      <!-- Featured Image (integrated naturally) -->
      {
        frontmatter.image && (
          <div class="mb-8 overflow-hidden rounded-xl">
            <Image
              class="h-auto w-full object-cover"
              src={frontmatter.image.url || frontmatter.image}
              alt={frontmatter.image.alt || frontmatter.title}
              loading="eager"
              widths={[375, 720, 900, 1350, 1800]}
              sizes="(max-width: 896px) 100vw, 896px"
              format="webp"
              quality={90}
              data-pagefind-meta="image[src]"
            />
          </div>
        )
      }

      <!-- Article Content (clean, no cards) -->
      <div class="relative overflow-hidden rounded-[2rem] border border-border/70 bg-card/45 px-5 py-6 shadow-[0_24px_80px_-48px_hsl(var(--foreground)/0.35)] backdrop-blur-sm sm:px-8 sm:py-8 md:px-10 md:py-10">
        <div class="pointer-events-none absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-primary/60 to-transparent"></div>
        <div
          class="article-prose prose mx-auto max-w-none lg:prose-lg xl:prose-xl
                prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-foreground
                prose-headings:scroll-mt-28 prose-h1:text-4xl prose-h2:mt-14 prose-h2:mb-5 prose-h2:text-3xl prose-h3:mt-10 prose-h3:mb-4 prose-h3:text-2xl
                prose-h4:mt-8 prose-h4:mb-3 prose-h4:text-xl prose-p:my-5 prose-p:text-lg prose-p:leading-relaxed prose-p:text-muted-foreground
                prose-a:font-medium prose-a:text-primary prose-a:underline prose-a:decoration-border prose-a:underline-offset-4
                hover:prose-a:text-foreground hover:prose-a:decoration-primary prose-a:transition-all prose-a:duration-200
                prose-blockquote:rounded-r-lg prose-blockquote:border-l-4 prose-blockquote:border-border prose-blockquote:bg-secondary/60 prose-blockquote:py-4 prose-blockquote:pl-6 prose-blockquote:pr-4
                prose-blockquote:not-italic prose-blockquote:text-muted-foreground prose-strong:font-semibold prose-strong:text-foreground prose-code:rounded prose-code:font-mono
                prose-code:text-base prose-code:text-foreground prose-code:before:content-[''] prose-code:after:content-[''] prose-pre:overflow-x-auto
                prose-pre:rounded-2xl prose-pre:bg-foreground
                prose-pre:p-6 prose-pre:text-primary-foreground prose-ol:pl-6 prose-ol:text-muted-foreground
                prose-ul:pl-6 prose-ul:text-muted-foreground prose-li:my-1 prose-li:text-lg prose-li:leading-relaxed prose-li:text-muted-foreground
                prose-hr:my-12 prose-hr:border-border/80 prose-table:my-10 prose-img:my-10
                prose-img:rounded-lg prose-img:shadow-md"
        >
          <slot />
        </div>
      </div>

      <!-- Share Button -->
      <div class="mt-12 flex justify-center">
        <ShareButton url={fullUrl} client:load />
      </div>

      <!-- Post Navigation (Prev/Next) -->
      <PostNavigation prevPost={prevPost} nextPost={nextPost} />

      <!-- Related Posts -->
      <RelatedPosts
        currentSlug={currentSlug}
        currentTags={frontmatter.tags || []}
        allPosts={allPosts}
      />

      <!-- Footer Actions -->
      <footer class="mt-12 border-t border-border pt-8">
        <div class="flex justify-center">
          <Button
            asChild
            variant="outline"
            className="border-border text-foreground transition-colors hover:bg-background"
          >
            <a href="/posts">← Back to All Articles</a>
          </Button>
        </div>
        <Toaster client:load />
      </footer>
    </div>
  </article>
</Layout>
