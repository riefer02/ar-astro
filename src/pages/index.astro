---
import Layout from "../layouts/Layout.astro";
import Analytics from "../components/Analytics.astro";
import HeroSection from "../components/HeroSection";
import ExpertiseSection from "../components/ExpertiseSection";
import EnhancedKeyProjects from "../components/EnhancedKeyProjects";
import ConnectSection from "../components/ConnectSection";
import keyProjects from "../lib/key-projects.json";

const metaTags = {
  title: "Andrew Riefenstahl | Full-Stack Software Engineer & AI Architect",
  description:
    "Andrew Riefenstahl is a full-stack software engineer and AI architect building secure web applications, MCP servers, and intelligent systems. Explore projects and technical insights.",
  url: "https://andrewriefenstahl.com",
  twitterHandle: "@riefer02",
};
---

<Layout metaTags={metaTags}>
  <Analytics />

  <!-- Modern spacing and structure -->
  <div class="space-y-0">
    <!-- Hero Section -->
    <HeroSection />

    <!-- Expertise Section -->
    <ExpertiseSection />

    <!-- Enhanced Projects Section -->
    <EnhancedKeyProjects keyProjects={keyProjects} />

    <!-- Connect Section -->
    <ConnectSection />
  </div>
</Layout>

<style>
  /* You can add custom Tailwind CSS styles here if needed */
</style>
